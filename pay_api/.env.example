# 三钥区别（避免 invalid-signature）：
# - ALIPAY_APP_PRIVATE_KEY / _FILE：应用私钥（仅本地），与开放平台「应用公钥」成对
# - ALIPAY_APP_PUBLIC_KEY（可选）：填开放平台复制的「应用公钥」，用于启动时本地校验与私钥是否成对
# - ALIPAY_PUBLIC_KEY：开放平台「查看支付宝公钥」，用于验签支付宝下行报文；不要填应用公钥

ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
# ALIPAY_APP_PRIVATE_KEY_FILE=/绝对路径/应用私钥.txt

ALIPAY_APP_PUBLIC_KEY=
ALIPAY_PUBLIC_KEY=

ALIPAY_SANDBOX=true
# ALIPAY_SERVER_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# 异步通知：支付宝 POST 到商户服务器，须公网 HTTPS（本地可用 ngrok 等）；与「支付完成浏览器回跳」无关
# 完整地址须与下方路由一致，例如：https://你的公网域名/api/pay/alipay/notify
ALIPAY_NOTIFY_URL=
# 公网 API 根（如 https://abc.ngrok-free.app）：未配 ALIPAY_NOTIFY_URL 时自动拼接为 {PUBLIC_API_BASE_URL}/api/pay/alipay/notify
# PUBLIC_API_BASE_URL=
# 同步跳转：支付完成后浏览器 GET 打开此地址；未填时默认使用「CORS_ORIGINS 第一个源 + /pay/return」
ALIPAY_RETURN_URL=http://localhost:5173/pay/return
CORS_ORIGINS=http://localhost:5173
HOST=0.0.0.0
PORT=8000

# PostgreSQL（asyncpg），示例：
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/pay_zhifubao

# 前端与后端 HTTP 接口说明见仓库根目录 docs/前端对接API.md

# 数据库结构由 Alembic 管理，首次/更新后请在 pay_api 目录执行：
#   uv run alembic upgrade head
# 若库里已有旧版应用启动时创建的 pay_transactions、但尚无 alembic 版本表，且表结构与当前迁移一致，可只打标不执行建表：
#   uv run alembic stamp head
# 新建迁移（改表结构后）：
#   uv run alembic revision -m "describe_change"
